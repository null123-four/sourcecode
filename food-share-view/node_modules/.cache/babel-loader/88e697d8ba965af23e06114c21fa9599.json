x;\r\n        margin: 0 10px;\r\n        \r\n        .cookbook-header {\r\n            .cookbook-title {\r\n                font-size: 28px;\r\n            }\r\n            \r\n            .cookbook-meta {\r\n                flex-direction: column;\r\n                gap: 10px;\r\n            }\r\n        }\r\n        \r\n        .cookbook-content {\r\n            .content-section {\r\n                &.structured-content {\r\n                    .section {\r\n                        .section-title {\r\n                            font-size: 20px;\r\n                        }\r\n                        \r\n                        .table-container {\r\n                            margin: 0 -20px;\r\n                            padding: 0 20px;\r\n                            \r\n                            .ingredients-table {\r\n                                min-width: 500px;\r\n                            }\r\n                        }\r\n                        \r\n                        &.steps-section {\r\n                            .steps-list {\r\n                                .step-item {\r\n                                    padding: 16px;\r\n                                    \r\n                                    .step-number {\r\n                                        width: 32px;\r\n                                        height: 32px;\r\n                                        font-size: 16px;\r\n                                    }\r\n                                    \r\n                                    .step-content {\r\n                                        .step-desc {\r\n                                            font-size: 15px;\r\n                                        }\r\n                                    }\r\n                                }\r\n                            }\r\n                        }\r\n                    }\r\n                }\r\n            }\r\n        }\r\n    }\r\n}\r\n</style>"],"mappings":";;;;