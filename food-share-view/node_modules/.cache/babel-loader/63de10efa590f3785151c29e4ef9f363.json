t: 5px;\">\r\n            <el-row style=\"display: flex;justify-content: left;gap: 6px;\">\r\n                <el-date-picker style=\"width: 216px;\" @change=\"fetchFreshData\" size=\"small\" v-model=\"searchTime\"\r\n                    type=\"daterange\" range-separator=\"至\" start-placeholder=\"操作开始\" end-placeholder=\"操作结束\">\r\n                </el-date-picker>\r\n                <el-input size=\"small\" style=\"width: 166px;\" v-model=\"interactionQueryDto.contentId\" placeholder=\"内容ID\"\r\n                    clearable @clear=\"handleFilterClear\">\r\n                    <el-button slot=\"append\" @click=\"handleFilter\" icon=\"el-icon-search\"></el-button>\r\n                </el-input>\r\n            </el-row>\r\n        </el-row>\r\n        <el-row style=\"margin: 0 22px;border-top: 1px solid rgb(245,245,245);\">\r\n            <el-table :stripe=\"true\" :data=\"tableData\" style=\"width: 100%\">\r\n                <el-table-column prop=\"userAvatar\" width=\"68\" label=\"头像\">\r\n                    <template slot-scope=\"scope\">\r\n                        <el-avatar :size=\"25\" :src=\"scope.row.userAvatar\" style=\"margin-top: 10px;\"></el-avatar>\r\n                    </template>\r\n                </el-table-column>\r\n                <el-table-column prop=\"userName\" label=\"用户\" width=\"208\"></el-table-column>\r\n                <el-table-column prop=\"contentId\" :sortable=\"true\"  width=\"120\" label=\"内容ID\" ></el-table-column>\r\n                <el-table-column prop=\"contentTitle\" label=\"内容\" ></el-table-column>\r\n                <el-table-column prop=\"type\" label=\"用户操作\" width=\"120\">\r\n                    <template slot-scope=\"scope\">\r\n                        <span v-if=\"scope.row.type === 1\">点赞</span>\r\n                        <span v-if=\"scope.row.type === 2\">收藏</span>\r\n                        <span v-if=\"scope.row.type === 3\">浏览</span>\r\n                        <span v-if=\"scope.row.type === 4\">用户评分({{ scope.row.score }})</span>\r\n                    </template>\r\n                </el-table-column>\r\n                <el-table-column prop=\"createTime\" label=\"创建时间\" :sortable=\"true\" width=\"168\"></el-table-column>\r\n                <el-table-column label=\"操作\" width=\"110\">\r\n                    <template slot-scope=\"scope\">\r\n                        <span class=\"text-button\" @click=\"handleDelete(scope.row)\">删除</span>\r\n                    </template>\r\n                </el-table-column>\r\n            </el-table>\r\n            <el-pagination style=\"margin:10px 0;float: right;\" @size-change=\"handleSizeChange\"\r\n                @current-change=\"handleCurrentChange\" :current-page=\"currentPage\" :page-sizes=\"[20, 50]\"\r\n                :page-size=\"pageSize\" layout=\"total, sizes, prev, pager, next, jumper\"\r\n                :total=\"totalItems\"></el-pagination>\r\n        </el-row>\r\n    </el-row>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n    data() {\r\n        return {\r\n            data: {},\r\n            filterText: '',\r\n            currentPage: 1,\r\n            pageSize: 20,\r\n            totalItems: 0,\r\n            tableData: [],\r\n            delectedRows: [],\r\n            searchTime: [],\r\n            interactionQueryDto: {}, // 搜索条件\r\n        };\r\n    },\r\n    created() {\r\n        this.fetchFreshData();\r\n    },\r\n    methods: {\r\n        // 批量删除数据\r\n        async batchDelete() {\r\n            if (!this.delectedRows.length) {\r\n                this.$message(`未选中任何数据`);\r\n                return;\r\n            }\r\n            const confirmed = await this.$swalConfirm({\r\n                title: '删除互动信息数据',\r\n                text: `删除后不可恢复，是否继续？`,\r\n                icon: 'warning',\r\n            });\r\n            if (confirmed) {\r\n                try {\r\n                    let ids = this.delectedRows.map(entity => entity.id);\r\n                    const response = await this.$axios.post(`/interaction/batchDelete`, ids);\r\n                    if (response.data.code === 200) {\r\n                        this.$notify({\r\n                            duration: 1000,\r\n                            title: '信息删除',\r\n                            message: '删除成功',\r\n                            type: 'success'\r\n                        });\r\n                        this.fetchFreshData();\r\n                        return;\r\n                    }\r\n                } catch (error) {\r\n                    this.$message.error(\"互动信息信息删除异常：\", error);\r\n                    console.error(`互动信息信息删除异常：`, error);\r\n                }\r\n            }\r\n        },\r\n        // 信息查询\r\n        async fetchFreshData() {\r\n            try {\r\n                this.tableData = [];\r\n                let startTime = null;\r\n                let endTime = null;\r\n                if (this.searchTime != null && this.searchTime.length === 2) {\r\n                    const [startDate, endDate] = await Promise.all(this.searchTime.map(date => date.toISOString()));\r\n                    startTime = `${startDate.split('T')[0]}T00:00:00`;\r\n                    endTime = `${endDate.split('T')[0]}T23:59:59`;\r\n                }\r\n                // 请求参数\r\n                const params = {\r\n                    current: this.currentPage,\r\n                    size: this.pageSize,\r\n                    key: this.filterText,\r\n                    startTime: startTime,\r\n                    endTime: endTime,\r\n                    ...this.interactionQueryDto\r\n                };\r\n                const response = await this.$axios.post('/interaction/query', params);\r\n                const { data } = response;\r\n                this.tableData = data.data;\r\n                this.totalItems = data.total;\r\n            } catch (error) {\r\n                this.$message.error(\"查询互动信息信息异常:\", error);\r\n                console.error('查询互动信息信息异常:', error);\r\n     