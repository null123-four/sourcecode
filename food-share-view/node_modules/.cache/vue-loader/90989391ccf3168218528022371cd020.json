{"remainingRequest":"D:\\food-share-system\\sourcecode\\food-share-view\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\food-share-system\\sourcecode\\food-share-view\\src\\views\\admin\\SeeGourmetDetail.vue?vue&type=style&index=0&id=7d877262&lang=scss&scoped=true&","dependencies":[{"path":"D:\\food-share-system\\sourcecode\\food-share-view\\src\\views\\admin\\SeeGourmetDetail.vue","mtime":1768132055984},{"path":"D:\\food-share-system\\sourcecode\\food-share-view\\node_modules\\css-loader\\dist\\cjs.js","mtime":499162500000},{"path":"D:\\food-share-system\\sourcecode\\food-share-view\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":499162500000},{"path":"D:\\food-share-system\\sourcecode\\food-share-view\\node_modules\\postcss-loader\\src\\index.js","mtime":499162500000},{"path":"D:\\food-share-system\\sourcecode\\food-share-view\\node_modules\\sass-loader\\dist\\cjs.js","mtime":499162500000},{"path":"D:\\food-share-system\\sourcecode\\food-share-view\\node_modules\\cache-loader\\dist\\cjs.js","mtime":499162500000},{"path":"D:\\food-share-system\\sourcecode\\food-share-view\\node_modules\\vue-loader\\lib\\index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["SeeGourmetDetail.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAkeA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA","file":"SeeGourmetDetail.vue","sourceRoot":"src/views/admin","sourcesContent":["<template>\r\n    <div style=\"width: 100%;\">\r\n        <el-row style=\"margin: 5px 0;\">\r\n            <h2 class=\"commentHeader\">评论与讨论</h2>\r\n            <el-row style=\"margin: 15px 0;\">\r\n                <el-col :span=\"2\">\r\n                    <el-avatar :src=\"userData.userAvatar\"></el-avatar>\r\n                </el-col>\r\n                <el-col :span=\"22\">\r\n                    <div class=\"parent-comment\">\r\n                        <textarea \r\n                            class=\"comment-parent-input\" \r\n                            v-model=\"content\" \r\n                            placeholder=\"请友好交流\"\r\n                            maxlength=\"300\"\r\n                        ></textarea>\r\n                        <div class=\"input-footer\">\r\n                            <span class=\"comment-input-number\">{{ content.length }} / 300</span>\r\n                            <el-button \r\n                                class=\"comment-click\" \r\n                                size=\"mini\" \r\n                                type=\"info\"\r\n                                :disabled=\"!content.trim()\"\r\n                            >\r\n                                评论\r\n                            </el-button>\r\n                        </div>\r\n                    </div>\r\n                </el-col>\r\n            </el-row>\r\n        </el-row>\r\n        <el-row style=\"margin: 5px 0px;\">\r\n            <el-row v-for=\"(comment, index) in commentList\" :key=\"index\" style=\"padding: 10px 0;\">\r\n                <el-row>\r\n                    <el-col :span=\"2\">\r\n                        <el-avatar size=\"large\" :src=\"comment.userAvatar\" class=\"user-avatar\"></el-avatar>\r\n                    </el-col>\r\n                    <el-col :span=\"22\">\r\n                        <span class=\"user-name\">{{ comment.userName }}</span>\r\n                        <span v-if=\"comment.userId == userId\" class=\"my-body-tag\">我自己</span>\r\n                    </el-col>\r\n                </el-row>\r\n                <el-row style=\"padding: 8px 0;\">\r\n                    <el-col :span=\"22\" :offset=\"2\">\r\n                        <span class=\"comment-content-text\">{{ comment.content }}</span>\r\n                    </el-col>\r\n                </el-row>\r\n                <el-row style=\"padding: 8px 0;\">\r\n                    <el-col :span=\"22\" :offset=\"2\">\r\n                        <div class=\"comment-footer\">\r\n                            <span class=\"comment-time\">评论于{{ comment.time }}</span>\r\n                            <el-popconfirm \r\n                                confirm-button-text='好的' \r\n                                cancel-button-text='不删了' \r\n                                icon=\"el-icon-info\"\r\n                                icon-color=\"red\" \r\n                                title=\"删除该条评论？\" \r\n                                v-if=\"comment.userId == userId\"\r\n                                @confirm=\"deleteComment(comment)\"\r\n                            >\r\n                                <span slot=\"reference\" class=\"action-btn delete-btn\">\r\n                                    <i class=\"el-icon-delete\"></i>\r\n                                    删除\r\n                                </span>\r\n                            </el-popconfirm>\r\n                            <span \r\n                                @click=\"toggleReplyInput(comment)\" \r\n                                class=\"action-btn reply-btn\"\r\n                            >\r\n                                <i class=\"el-icon-chat-dot-round\"></i>\r\n                                回复<span v-if=\"comment.childTotal != 0\">({{ comment.childTotal }})</span>\r\n                            </span>\r\n                            <span \r\n                                @click=\"upvote(comment)\" \r\n                                class=\"action-btn upvote-btn\"\r\n                            >\r\n                                <span>\r\n                                    <span v-if=\"!comment.upvoteFlag\">\r\n                                        <i class=\"el-icon-thumb\"></i>\r\n                                        {{ comment.upvoteCount === null ? 0 : comment.upvoteCount }}\r\n                                    </span>\r\n                                    <span v-else>\r\n                                        <i class=\"el-icon-thumb\" style=\"color: #4b87bc;\"></i>\r\n                                        &nbsp;{{ comment.upvoteCount }}\r\n                                    </span>\r\n                                </span>\r\n                            </span>\r\n                        </div>\r\n\r\n                    </el-col>\r\n                </el-row>\r\n                <!-- 父级评论的回复按钮和输入框 -->\r\n                <el-row v-if=\"comment.showReplyInput\" style=\"padding: 10px 0;\">\r\n                    <el-col :span=\"22\" :offset=\"2\">\r\n                        <div class=\"parent-comment\">\r\n                            <textarea \r\n                                class=\"comment-parent-input\" \r\n                                v-model=\"replyContent\" \r\n                                placeholder=\"我要回复\"\r\n                                maxlength=\"300\"\r\n                            ></textarea>\r\n                            <div class=\"input-footer\">\r\n                                <span class=\"comment-input-number\">{{ replyContent.length }} / 300</span>\r\n                                <el-button \r\n                                    class=\"comment-click\" \r\n                                    size=\"mini\" \r\n                                    type=\"info\"\r\n                                    :disabled=\"!replyContent.trim()\"\r\n                                    @click=\"submitReply(comment)\"\r\n                                >\r\n                                    评论\r\n                                </el-button>\r\n                            </div>\r\n                        </div>\r\n                    </el-col>\r\n                </el-row>\r\n                <!-- 子级评论 -->\r\n                <el-row \r\n                    v-for=\"(commentChild, index) in comment.commentChildVOS\" \r\n                    :key=\"index\"\r\n                    class=\"child-comment-item\"\r\n                >\r\n                    <el-row>\r\n                        <el-col :span=\"22\" :offset=\"2\">\r\n                            <el-row class=\"child-comment-header\">\r\n                                <el-avatar \r\n                                    size=\"small\" \r\n                                    :src=\"commentChild.userAvatar\"\r\n                                    class=\"child-avatar\"\r\n                                ></el-avatar>\r\n                                <span class=\"child-user-name\">{{ commentChild.userName }}</span>\r\n                                <span v-if=\"commentChild.userId == userId\" class=\"my-body-tag\">我自己</span>\r\n                                <span \r\n                                    v-if=\"commentChild.replierName != null\"\r\n                                    class=\"reply-indicator\"\r\n                                >\r\n                                    回复\r\n                                </span>\r\n                                <el-avatar \r\n                                    v-if=\"commentChild.replierName != null\" \r\n                                    size=\"small\"\r\n                                    :src=\"commentChild.replierAvatar\" \r\n                                    class=\"replier-avatar\"\r\n                                ></el-avatar>\r\n                                <span \r\n                                    v-if=\"commentChild.replierName != null\" \r\n                                    class=\"replier-name\"\r\n                                >\r\n                                    {{ commentChild.replierName }}\r\n                                </span>\r\n                                <span v-if=\"commentChild.replierId == userId\" class=\"my-body-tag\">我自己</span>\r\n                                <span class=\"child-comment-content\">\r\n                                    : {{ commentChild.content }}\r\n                                </span>\r\n                            </el-row>\r\n                            <el-row class=\"child-comment-footer\">\r\n                                <span class=\"comment-time\">评论于{{ commentChild.time }}</span>\r\n                                <el-popconfirm \r\n                                    confirm-button-text='好的' \r\n                                    cancel-button-text='不删了' \r\n                                    icon=\"el-icon-info\"\r\n                                    icon-color=\"red\" \r\n                                    title=\"删除该条评论？\" \r\n                                    v-if=\"commentChild.userId == userId\"\r\n                                    @confirm=\"deleteComment(commentChild)\"\r\n                                >\r\n                                    <span slot=\"reference\" class=\"action-btn delete-btn\">\r\n                                        <i class=\"el-icon-delete\"></i>\r\n                                        删除\r\n                                    </span>\r\n                                </el-popconfirm>\r\n                                <span \r\n                                    @click=\"toggleReplyInput1(commentChild)\" \r\n                                    class=\"action-btn reply-btn\"\r\n                                >\r\n                                    <i class=\"el-icon-chat-dot-round\"></i>\r\n                                    回复\r\n                                </span>\r\n                                <span \r\n                                    @click=\"upvote(commentChild)\" \r\n                                    class=\"action-btn upvote-btn\"\r\n                                >\r\n                                    <span>\r\n                                        <span v-if=\"!commentChild.upvoteFlag\">\r\n                                            <i class=\"el-icon-thumb\"></i>\r\n                                            {{ commentChild.upvoteCount === null ? 0 : commentChild.upvoteCount }}\r\n                                        </span>\r\n                                        <span v-else>\r\n                                            <i class=\"el-icon-thumb\" style=\"color: #4b87bc;\"></i>\r\n                                            &nbsp;{{ commentChild.upvoteCount }}\r\n                                        </span>\r\n                                    </span>\r\n                                </span>\r\n                            </el-row>\r\n                            <!-- 子级评论的回复按钮和输入框 -->\r\n                            <el-row v-if=\"commentChild.replyInputStatus\" style=\"padding: 10px 0;\">\r\n                                <el-col :span=\"24\">\r\n                                    <div class=\"parent-comment\">\r\n                                        <textarea \r\n                                            class=\"comment-parent-input\" \r\n                                            v-model=\"replyChildContent\" \r\n                                            placeholder=\"我要回复\"\r\n                                            maxlength=\"300\"\r\n                                        ></textarea>\r\n                                        <div class=\"input-footer\">\r\n                                            <span class=\"comment-input-number\">{{ replyChildContent.length }} / 300</span>\r\n                                            <el-button \r\n                                                class=\"comment-click\" \r\n                                                size=\"mini\" \r\n                                                type=\"info\"\r\n                                                :disabled=\"!replyChildContent.trim()\"\r\n                                                @click=\"submitReply1(commentChild)\"\r\n                                            >\r\n                                                评论\r\n                                            </el-button>\r\n                                        </div>\r\n                                    </div>\r\n                                </el-col>\r\n                            </el-row>\r\n                        </el-col>\r\n                    </el-row>\r\n                </el-row>\r\n            </el-row>\r\n        </el-row>\r\n    </div>\r\n</template>\r\n\r\n<script>\r\nimport { timeAgo } from '@/utils/data'\r\nexport default {\r\n    props: {\r\n        contentId: {\r\n            type: Number,\r\n            default: ''\r\n        },\r\n        contentType: {\r\n            type: String,\r\n            default: ''\r\n        }\r\n    },\r\n    data() {\r\n        return {\r\n            userData: {},\r\n            noteData: {},\r\n            commentContent: '',\r\n            content: '',\r\n            commentList: [],\r\n            replyContent: '',\r\n            id: null,\r\n            isFocused: false,\r\n            bgColor: 'rgb(245 245 245)',\r\n            strLength: '0/300',\r\n            replyText: '',\r\n            userId: '',\r\n            selectdStatus: false,\r\n            evaluationsCount: 0,\r\n            comment: {},\r\n            replyChildContent: '',\r\n        };\r\n    },\r\n    watch: {\r\n        contentId(newVal, oldVal) {\r\n            if (newVal !== oldVal) {\r\n                this.loadCommentList();\r\n            }\r\n        },\r\n        content() {\r\n            if (this.content === '') {\r\n                this.isFocused = false;\r\n                return;\r\n            }\r\n        },\r\n    },\r\n    created() {\r\n        this.getUserInfo();\r\n        this.loadCommentList();\r\n    },\r\n    methods: {\r\n        getUserInfo() {\r\n            const userInfo = sessionStorage.getItem(\"userInfo\");\r\n            this.userData = JSON.parse(userInfo);\r\n            this.userId = this.userData.id;\r\n        },\r\n        // 点赞 或 取消点赞\r\n        upvote(comment) {\r\n            this.$axios.post(`evaluations/upvoteOperation`, { id: comment.id }).then(res => {\r\n                if (res.data.code == 200) {\r\n                    let rep = res.data.data;\r\n                    console.log(rep);\r\n                    comment.upvoteCount = Number(rep.count);\r\n                    comment.upvoteFlag = Boolean(rep.haveUpvote);\r\n                }\r\n            }).catch(err => {\r\n                console.error(`点赞操作异常 -> `, err);\r\n            })\r\n        },\r\n        deleteComment(comment) { // 删除评论\r\n            this.$axios.delete(`evaluations/delete/${comment.id}`).then(res => {\r\n                if (res.data.code == 200) {\r\n                    this.$message.success(res.data.msg);\r\n                    this.loadCommentList();\r\n                }\r\n            }).catch(err => {\r\n                console.error(`评论异常 -> `, err);\r\n            })\r\n        },\r\n        onFocus() {\r\n            this.isFocused = true;\r\n        },\r\n        // 输入框失去焦点\r\n        onBlur() {\r\n            if (this.content === '') {\r\n                this.isFocused = false;\r\n                return;\r\n            }\r\n            this.isFocused = true;\r\n        },\r\n        commentClick() {\r\n            if (this.content == '') {\r\n                this.$swal.fire({\r\n                    title: '内容提示',\r\n                    text: '评论内容为空',\r\n                    icon: 'success',\r\n                    showConfirmButton: false,\r\n                    timer: 800\r\n                });\r\n                return;\r\n            }\r\n            const evaluations = {\r\n                contentType: this.contentType,\r\n                content: this.content,\r\n                contentId: this.contentId,\r\n            }\r\n            this.$axios.post(`evaluations/insert`, evaluations).then(res => {\r\n                if (res.data.code == 200) {\r\n                    this.content = '';\r\n                    this.$swal.fire({\r\n                        title: '评论操作',\r\n                        text: '评论成功',\r\n                        icon: 'success',\r\n                        showConfirmButton: false,\r\n                        timer: 1100\r\n                    });\r\n                    setTimeout(() => {\r\n                        this.loadCommentList()\r\n                    }, 1100)\r\n                } else {\r\n                    this.$swal.fire({\r\n                        title: '评论异常',\r\n                        text: res.data.msg,\r\n                        icon: 'error',\r\n                        showConfirmButton: false,\r\n                        timer: 1100\r\n                    });\r\n                }\r\n            }).catch(err => {\r\n                console.error(`评论异常 -> `, err);\r\n            })\r\n        },\r\n        // 父级评论回复点击\r\n        toggleReplyInput(comment) {\r\n            this.replyText = `回复${comment.userName}...`;\r\n            if (comment.showReplyInput == null) {\r\n                comment.showReplyInput = false;\r\n            }\r\n            comment.showReplyInput = !comment.showReplyInput;\r\n        },\r\n        // 子级评论回复点击\r\n        toggleReplyInput1(comment) {\r\n            if (comment.replyInputStatus == null) {\r\n                comment.replyInputStatus = false;\r\n            }\r\n            comment.replyInputStatus = !comment.replyInputStatus;\r\n        },\r\n        // 父级评论回复提交\r\n        submitReply(comment) {\r\n            if (this.replyContent == '') {\r\n                this.$message(`评论内容不能为空`);\r\n                return;\r\n            }\r\n            const evaluationsDTO = {\r\n                contentType: this.contentType,\r\n                content: this.replyContent,\r\n                contentId: this.contentId,\r\n                parentId: comment.id\r\n            }\r\n            this.$axios.post(`evaluations/insert`, evaluationsDTO).then(res => {\r\n                if (res.data.code == 200) {\r\n                    this.replyContent = '';\r\n                    comment.showReplyInput = false;\r\n                    this.$swal.fire({\r\n                        title: '回复操作',\r\n                        text: '回复成功',\r\n                        icon: 'success',\r\n                        showConfirmButton: false,\r\n                        timer: 1300\r\n                    });\r\n                    setTimeout(() => {\r\n                        // 重新加载评论列表\r\n                        this.loadCommentList();\r\n                    }, 1300)\r\n                } else {\r\n                    this.$swal.fire({\r\n                        title: '评论异常',\r\n                        text: res.data.msg,\r\n                        icon: 'error',\r\n                        showConfirmButton: false,\r\n                        timer: 1100\r\n                    });\r\n                }\r\n            }).catch(err => {\r\n                console.error(`评论异常 -> `, err);\r\n            })\r\n        },\r\n        // 子级评论回复提交\r\n        submitReply1(comment) {\r\n            if (this.replyChildContent == '') {\r\n                this.$message(`评论内容不能为空`);\r\n                return;\r\n            }\r\n            const evaluationsDTO = {\r\n                replierId: comment.userId,\r\n                contentType: this.contentType,\r\n                content: this.replyChildContent,\r\n                contentId: this.contentId,\r\n                parentId: comment.parentId\r\n            }\r\n            this.$axios.post(`evaluations/insert`, evaluationsDTO).then(res => {\r\n                if (res.data.code == 200) {\r\n                    this.content = '';\r\n                    comment.replyInputStatus = false;\r\n                    this.$swal.fire({\r\n                        title: '回复操作',\r\n                        text: '回复成功',\r\n                        icon: 'success',\r\n                        showConfirmButton: false,\r\n                        timer: 1300\r\n                    });\r\n                    setTimeout(() => {\r\n                        // 重新加载评论列表\r\n                        this.loadCommentList();\r\n                    }, 1300)\r\n                } else {\r\n                    this.$swal.fire({\r\n                        title: '评论异常',\r\n                        text: res.data.msg,\r\n                        icon: 'error',\r\n                        showConfirmButton: false,\r\n                        timer: 1100\r\n                    });\r\n                }\r\n            }).catch(err => {\r\n                console.error(`评论异常 -> `, err);\r\n            })\r\n        },\r\n        goBack() {\r\n            // 返回上一级\r\n            this.$router.go(-1);\r\n        },\r\n        // 加载评论列表\r\n        loadCommentList() {\r\n            this.$axios.get(`evaluations/list/${this.contentId}/${this.contentType}`).then(res => {\r\n                if (res.data.code == 200) {\r\n                    this.commentList = res.data.data.data;\r\n                    this.evaluationsCount = res.data.data.evaluationsCount;\r\n                    // 父级评论\r\n                    this.commentList.forEach(entity => {\r\n                        // 时间转换\r\n                        entity.time = timeAgo(entity.createTime);\r\n                        // 子级评论\r\n                        entity.commentChildVOS.forEach(entity => entity.time = timeAgo(entity.createTime));\r\n                    });\r\n                }\r\n            }).catch(err => {\r\n                console.error(`评论查询异常异常 -> `, err);\r\n            })\r\n        },\r\n    }\r\n};  \r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n/* 整体样式 */\r\n.commentHeader {\r\n    color: #8B4513; /* 棕色标题 */\r\n    font-size: 18px;\r\n    font-weight: 600;\r\n    line-height: 30px;\r\n    margin: 0;\r\n    padding: 0;\r\n}\r\n\r\n/* 输入框区域 */\r\n.parent-comment {\r\n    padding: 12px;\r\n    border-radius: 4px;\r\n    background-color: #fff;\r\n    border: 1px solid #e5e5e5;\r\n    position: relative;\r\n    margin-bottom: 16px;\r\n}\r\n\r\n.comment-parent-input {\r\n    outline: none;\r\n    border: none;\r\n    background-color: transparent;\r\n    font-size: 14px;\r\n    width: 100%;\r\n    min-height: 60px;\r\n    overflow: auto;\r\n    resize: none;\r\n    margin: 0 0 10px 0;\r\n    display: block;\r\n    color: #333;\r\n    line-height: 1.5;\r\n    \r\n    &::placeholder {\r\n        color: #999;\r\n    }\r\n}\r\n\r\n.input-footer {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: center;\r\n    border-top: 1px solid #f0f0f0;\r\n    padding-top: 8px;\r\n}\r\n\r\n.comment-input-number {\r\n    font-size: 12px;\r\n    color: #999;\r\n}\r\n\r\n.comment-click {\r\n    background-color: #f5f5f5;\r\n    border-color: #f5f5f5;\r\n    color: #999;\r\n    font-size: 12px;\r\n    padding: 4px 12px;\r\n    height: 28px;\r\n    \r\n    &:hover {\r\n        background-color: #e8e8e8;\r\n        border-color: #e8e8e8;\r\n    }\r\n    \r\n    &:disabled {\r\n        opacity: 0.5;\r\n        cursor: not-allowed;\r\n    }\r\n}\r\n\r\n/* 用户信息 */\r\n.user-avatar {\r\n    border: 1px solid #f0f0f0;\r\n}\r\n\r\n.user-name {\r\n    height: 40px;\r\n    line-height: 40px;\r\n    font-size: 14px;\r\n    color: #333;\r\n    font-weight: 500;\r\n}\r\n\r\n.my-body-tag {\r\n    font-size: 12px;\r\n    padding: 2px 6px;\r\n    color: #409EFF; /* 蓝色标签 */\r\n    background-color: rgba(64, 158, 255, 0.1);\r\n    border-radius: 2px;\r\n    margin-left: 8px;\r\n    height: 20px;\r\n    line-height: 16px;\r\n    display: inline-block;\r\n}\r\n\r\n/* 评论内容 */\r\n.comment-content-text {\r\n    font-size: 14px;\r\n    color: #333;\r\n    line-height: 1.5;\r\n}\r\n\r\n/* 评论底部信息 */\r\n.comment-footer {\r\n    display: flex;\r\n    align-items: center;\r\n    gap: 16px;\r\n}\r\n\r\n.comment-time {\r\n    font-size: 12px;\r\n    color: #999;\r\n}\r\n\r\n.action-btn {\r\n    cursor: pointer;\r\n    font-size: 12px;\r\n    color: #999;\r\n    user-select: none;\r\n    display: flex;\r\n    align-items: center;\r\n    gap: 4px;\r\n    transition: color 0.2s;\r\n    \r\n    i {\r\n        font-size: 14px;\r\n    }\r\n    \r\n    &:hover {\r\n        color: #333;\r\n    }\r\n    \r\n    &.delete-btn:hover {\r\n        color: #f56c6c;\r\n    }\r\n    \r\n    &.reply-btn:hover {\r\n        color: #409EFF;\r\n    }\r\n    \r\n    &.upvote-btn:hover {\r\n        color: #4b87bc;\r\n    }\r\n}\r\n\r\n/* 子评论样式 */\r\n.child-comment-item {\r\n    padding: 10px 15px;\r\n    font-size: 14px;\r\n    background-color: #fafafa;\r\n    border-radius: 4px;\r\n    margin-top: 8px;\r\n    margin-left: 40px;\r\n}\r\n\r\n.child-comment-header {\r\n    display: flex;\r\n    align-items: center;\r\n    flex-wrap: wrap;\r\n    gap: 8px;\r\n    margin-bottom: 6px;\r\n}\r\n\r\n.child-avatar {\r\n    border: 1px solid #f0f0f0;\r\n}\r\n\r\n.replier-avatar {\r\n    border: 1px solid #f0f0f0;\r\n}\r\n\r\n.child-user-name {\r\n    color: #515767;\r\n    font-size: 13px;\r\n    font-weight: 500;\r\n}\r\n\r\n.reply-indicator {\r\n    margin: 0 4px;\r\n    color: #1c1c1c;\r\n    user-select: none;\r\n    font-size: 12px;\r\n}\r\n\r\n.replier-name {\r\n    color: #515767;\r\n    font-size: 13px;\r\n    font-weight: 500;\r\n}\r\n\r\n.child-comment-content {\r\n    letter-spacing: 0.5px;\r\n    font-size: 13px;\r\n    color: #333;\r\n    white-space: normal;\r\n    line-height: 1.5;\r\n    margin-left: 4px;\r\n    flex: 1;\r\n}\r\n\r\n.child-comment-footer {\r\n    padding: 6px 0;\r\n    display: flex;\r\n    align-items: center;\r\n    gap: 16px;\r\n}\r\n\r\n/* 按钮弹窗样式 */\r\n.cannel-btn,\r\n.yes-btn {\r\n    padding: 0px 15px 5px 15px;\r\n    font-size: 14px !important;\r\n    margin: 0 10px;\r\n    border-radius: 3px;\r\n    border: none;\r\n}\r\n\r\n.cannel-btn {\r\n    color: #1c1c1c;\r\n}\r\n\r\n.yes-btn {\r\n    background-color: #4b87bc;\r\n    color: #EAF2FF;\r\n}\r\n\r\n.cannel-btn:hover {\r\n    background-color: #f5f5f5;\r\n}\r\n\r\n.yes-btn:hover {\r\n    background-color: #66a8e1;\r\n}\r\n\r\n/* 响应式调整 */\r\n@media (max-width: 768px) {\r\n    .child-comment-item {\r\n        margin-left: 20px;\r\n    }\r\n    \r\n    .child-comment-header {\r\n        flex-direction: column;\r\n        align-items: flex-start;\r\n        gap: 4px;\r\n    }\r\n    \r\n    .child-comment-content {\r\n        margin-left: 0;\r\n        margin-top: 4px;\r\n    }\r\n}\r\n</style>"]}]}